# ============================================================
# JIM App V2 — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# ============================================================

# --- Supabase (mobile Expo) ---
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Supabase (web Next.js) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Sentry ---
SENTRY_DSN=https://your-dsn@sentry.io/your-project
EXPO_PUBLIC_SENTRY_DSN=https://your-dsn@sentry.io/your-project

# --- Edge Functions (Supabase Secrets — JAMAIS cote client) ---
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ANNUAIRE_SANTE_API_KEY=your-api-key

# --- Stripe Connect — Epic 9 ---
# SANDBOX UNIQUEMENT — cles live BLOQUEES jusqu'a validation HDS (~M5)
STRIPE_SECRET_KEY=sk_test_your-test-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRO_PRICE_ID=price_test_your-pro-price-id

# --- Firebase Cloud Messaging — Epic 7 ---
FCM_PROJECT_ID=your-firebase-project-id
FCM_ACCESS_TOKEN=your-fcm-access-token

# --- Support email — Epic 12 ---
SUPPORT_EMAIL=nathan@jim.app
