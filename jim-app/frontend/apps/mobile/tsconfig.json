{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-native",
    "lib": [
      "ES2022"
    ],
    "moduleResolution": "bundler",
    "paths": {
      "@jim/shared": [
        "../../packages/shared/src/index.ts"
      ],
      "@jim/shared/*": [
        "../../packages/shared/src/*"
      ],
      "@jim/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@jim/ui/*": [
        "../../packages/ui/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.d.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts",
    ".expo/types/**/*.ts"
  ]
}
