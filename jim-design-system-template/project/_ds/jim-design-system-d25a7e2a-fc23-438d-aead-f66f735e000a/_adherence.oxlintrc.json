{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "header-app.jsx",
              "header-variants.jsx",
              "menu-app.jsx",
              "menu-features.jsx",
              "menu-page.jsx",
              "menu-shared.jsx",
              "menu-variant-a.jsx",
              "menu-variant-b.jsx",
              "menu-variant-c.jsx",
              "tweaks-panel.jsx",
              "ui_kits/mobile/**",
              "ui_kits/web/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Manrope|Fraunces))/i]",
        "message": "Font not provided by the design system. Available: Manrope, Fraunces."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
    "components": {},
    "tokens": [
      "--font-mono",
      "--font-sans",
      "--font-serif-italic",
      "--jim-accent",
      "--jim-accent-warm",
      "--jim-background",
      "--jim-beige-dark",
      "--jim-beige-light",
      "--jim-beige-mid",
      "--jim-border",
      "--jim-destructive",
      "--jim-destructive-bg",
      "--jim-duration-fast",
      "--jim-duration-normal",
      "--jim-duration-slow",
      "--jim-ease",
      "--jim-ease-fade",
      "--jim-ease-out",
      "--jim-ease-spring",
      "--jim-muted",
      "--jim-primary",
      "--jim-primary-mid",
      "--jim-primary-pale",
      "--jim-primary-soft",
      "--jim-radius",
      "--jim-radius-full",
      "--jim-radius-lg",
      "--jim-radius-sm",
      "--jim-radius-xl",
      "--jim-shadow",
      "--jim-shadow-hover",
      "--jim-shadow-lg",
      "--jim-shadow-md",
      "--jim-shadow-sm",
      "--jim-shadow-xl",
      "--jim-space-2xl",
      "--jim-space-lg",
      "--jim-space-md",
      "--jim-space-sm",
      "--jim-space-xl",
      "--jim-space-xs",
      "--jim-success",
      "--jim-success-bg",
      "--jim-surface",
      "--jim-surface-alt",
      "--jim-text",
      "--jim-text-body",
      "--jim-warning",
      "--jim-warning-bg"
    ],
    "tokenKinds": {
      "--font-sans": "font",
      "--font-serif-italic": "font",
      "--font-mono": "font",
      "--jim-primary": "color",
      "--jim-primary-mid": "color",
      "--jim-primary-soft": "color",
      "--jim-primary-pale": "color",
      "--jim-accent": "color",
      "--jim-accent-warm": "color",
      "--jim-background": "color",
      "--jim-surface": "color",
      "--jim-surface-alt": "color",
      "--jim-beige-dark": "color",
      "--jim-beige-mid": "color",
      "--jim-beige-light": "color",
      "--jim-text": "font",
      "--jim-text-body": "font",
      "--jim-muted": "color",
      "--jim-border": "color",
      "--jim-success": "color",
      "--jim-success-bg": "color",
      "--jim-warning": "color",
      "--jim-warning-bg": "color",
      "--jim-destructive": "color",
      "--jim-destructive-bg": "color",
      "--jim-shadow-sm": "shadow",
      "--jim-shadow": "shadow",
      "--jim-shadow-md": "shadow",
      "--jim-shadow-lg": "shadow",
      "--jim-shadow-xl": "shadow",
      "--jim-shadow-hover": "shadow",
      "--jim-radius-sm": "radius",
      "--jim-radius": "radius",
      "--jim-radius-lg": "radius",
      "--jim-radius-xl": "radius",
      "--jim-radius-full": "radius",
      "--jim-space-xs": "spacing",
      "--jim-space-sm": "spacing",
      "--jim-space-md": "spacing",
      "--jim-space-lg": "spacing",
      "--jim-space-xl": "spacing",
      "--jim-space-2xl": "spacing",
      "--jim-duration-fast": "other",
      "--jim-duration-normal": "other",
      "--jim-duration-slow": "other",
      "--jim-ease": "other",
      "--jim-ease-out": "other",
      "--jim-ease-spring": "other",
      "--jim-ease-fade": "other"
    },
    "fontFamilies": [
      "Fraunces",
      "Manrope"
    ]
  }
}